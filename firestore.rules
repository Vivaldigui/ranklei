rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        (
          request.auth.token.email in ['gui.rib.pi@gmail.com'] ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    match /profiles/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /userStates/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if isAdmin()
          || (signedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /questionStats/{questionId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /answers/{answerId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notebooks/{notebookId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /savedFilters/{filterId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if signedIn() && (resource.data.isPrivate != true || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /questionReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /laws/{lawId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }
  }
}
